<form method="post" action="{{ path('app_address_delete', {'id': address.id}) }}" onsubmit="return confirm('ALERTE : suppression du GeoNode demandée. Confirmer la purge des coordonnées ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ address.id) }}">
    <button class="w-full py-2 border border-[var(--color-drac-red)]/40 text-[var(--color-drac-red)] text-xs font-mono rounded hover:bg-[var(--color-drac-red)] hover:text-[var(--color-drac-bg)] transition-all uppercase tracking-widest">
        Purge_Coords
    </button>
</form>
