{% extends 'base.html.twig' %}

{% block title %}GeoRegistry - Endereços{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono text-[var(--color-drac-fg)]">
    <div class="max-w-7xl mx-auto space-y-8">
        
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-purple)] tracking-tight uppercase">
                    <span class="text-[var(--color-drac-cyan)]">@</span> geo_coordinates
                </h1>
                <p class="text-sm text-[var(--color-drac-comment)] mt-1">Synchronisation de la base de données des emplacements physiques...</p>
            </div>
            
            <a href="{{ path('app_address_new') }}" class="inline-flex items-center px-6 py-3 bg-[var(--color-drac-purple)]/10 border border-[var(--color-drac-purple)]/30 text-[var(--color-drac-purple)] rounded-xl text-sm hover:bg-[var(--color-drac-purple)] hover:text-[var(--color-drac-bg)] transition-all shadow-lg hover:shadow-[var(--color-drac-purple)]/20 uppercase tracking-widest">
                <span class="mr-2">+</span> Reg_Loc_Node
            </a>
        </div>

        <div class="bg-[var(--color-drac-surface)]/40 border border-[var(--color-drac-curr)] rounded-2xl overflow-hidden backdrop-blur-sm shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-[var(--color-drac-curr)]/50 text-[var(--color-drac-cyan)] uppercase tracking-wider">
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">ID</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">Alias/Label</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">Street_Data</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] hidden md:table-cell">Zip_Code</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">City_Node</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-right">Acoes</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[var(--color-drac-curr)]">
                    {% for address in addresses %}
                        <tr class="hover:bg-[var(--color-drac-purple)]/5 transition-colors group">
                            <td class="px-6 py-4 text-[var(--color-drac-comment)] font-bold">#{{ address.id }}</td>
                            <td class="px-6 py-4">
                                <span class="font-bold text-[var(--color-drac-pink)] uppercase text-xs">{{ address.alias }}</span>
                            </td>
                            <td class="px-6 py-4 truncate max-w-xs opacity-80">
                                {{ address.street }}
                            </td>
                            <td class="px-6 py-4 hidden md:table-cell text-[var(--color-drac-green)] font-mono">
                                {{ address.zipCode }}
                            </td>
                            <td class="px-6 py-4 text-[var(--color-drac-fg)]">
                                {{ address.city }}
                            </td>
                            <td class="px-6 py-4 text-right space-x-3">
                                <a href="{{ path('app_address_show', {'id': address.id}) }}" class="text-[var(--color-drac-purple)] hover:text-[var(--color-drac-cyan)] transition-colors underline decoration-[var(--color-drac-purple)]/20 uppercase text-xs">gps</a>
                                <a href="{{ path('app_address_modifier', {'id': address.id}) }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-pink)] transition-colors underline decoration-[var(--color-drac-comment)]/20 uppercase text-xs">mod</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-20 text-center text-[var(--color-drac-comment)] italic">
                                <p class="text-lg">HORS_RÉSEAU : aucune adresse enregistrée trouvée.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>
{% endblock %}
