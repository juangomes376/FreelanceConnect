{% extends 'base.html.twig' %}

{% block title %}Connexion - FreelanceConnect{% endblock %}

{% block body %}
<main class="flex flex-col items-center justify-center flex-grow p-4 sm:p-6 bg-[var(--color-drac-bg)] relative overflow-hidden">
    {# Decorações de fundo Cyberpunk #}
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-[var(--color-drac-purple)]/10 rounded-full blur-3xl opacity-50"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-[var(--color-drac-pink)]/10 rounded-full blur-3xl opacity-50"></div>

    <div class="w-full max-w-md p-8 pt-10 space-y-8 bg-[var(--color-drac-surface)]/60 border border-[var(--color-drac-curr)] rounded-2xl shadow-2xl backdrop-blur-xl relative z-10 neon-border-purple">
        <div class="text-center">
            <h1 class="text-3xl font-bold tracking-tight text-[var(--color-drac-purple)] font-mono">
                <span class="text-[var(--color-drac-pink)]">&gt;</span> Login
            </h1>
            <p class="mt-2 text-sm text-[var(--color-drac-comment)] font-mono">Accès restreint :: Console développeur</p>
        </div>

        <form method="post" class="space-y-6">
            {% if error %}
                <div class="p-4 text-sm text-[var(--color-drac-red)] bg-[var(--color-drac-red)]/10 border border-[var(--color-drac-red)]/30 rounded-lg font-mono">
                    ERROR: {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="p-4 text-sm text-[var(--color-drac-cyan)] bg-[var(--color-drac-cyan)]/10 border border-[var(--color-drac-cyan)]/30 rounded-lg mb-6 font-mono">
                    STATUT : Connecté en tant que <span class="font-bold">{{ app.user.userIdentifier }}</span>. <a href="{{ logout_path() }}" class="text-[var(--color-drac-pink)] underline hover:text-[var(--color-drac-purple)] transition-colors">Annuler la session</a>
                </div>
            {% endif %}

            <div class="space-y-5">
                <div>
                    <label for="inputEmail" class="block text-xs font-mono text-[var(--color-drac-cyan)] uppercase tracking-widest mb-2">E-mail</label>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="block w-full px-4 py-3 text-[var(--color-drac-fg)] bg-[var(--color-drac-bg)]/80 border border-[var(--color-drac-curr)] rounded-lg shadow-sm focus:ring-2 focus:ring-[var(--color-drac-purple)] focus:border-[var(--color-drac-purple)] focus:outline-none sm:text-sm transition-all placeholder-[var(--color-drac-comment)] font-mono" placeholder="dev@example.com" autocomplete="email" required autofocus>
                </div>

                <div>
                    <label for="inputPassword" class="block text-xs font-mono text-[var(--color-drac-cyan)] uppercase tracking-widest mb-2">Password</label>
                    <input type="password" name="password" id="inputPassword" class="block w-full px-4 py-3 text-[var(--color-drac-fg)] bg-[var(--color-drac-bg)]/80 border border-[var(--color-drac-curr)] rounded-lg shadow-sm focus:ring-2 focus:ring-[var(--color-drac-pink)] focus:border-[var(--color-drac-pink)] focus:outline-none sm:text-sm transition-all placeholder-[var(--color-drac-comment)] font-mono" placeholder="********" autocomplete="current-password" required>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input id="remember_me" name="_remember_me" type="checkbox" class="w-4 h-4 text-[var(--color-drac-purple)] bg-[var(--color-drac-bg)] border-[var(--color-drac-curr)] rounded focus:ring-[var(--color-drac-purple)]">
                    <label for="remember_me" class="block ml-2 text-xs text-[var(--color-drac-comment)] font-mono">
                        Maintenir la session persistante
                    </label>
                </div>
            </div>

            <button type="submit" class="flex justify-center w-full px-4 py-3 text-sm font-bold text-[var(--color-drac-bg)] bg-[var(--color-drac-purple)] rounded-lg shadow-lg hover:bg-[var(--color-drac-pink)] hover:shadow-[var(--color-drac-pink)]/40 focus:outline-none transition-all font-mono uppercase tracking-widest">
                Connexion
            </button>
            
            <p class="text-xs text-center text-[var(--color-drac-comment)] mt-6 pt-6 border-t border-[var(--color-drac-curr)] font-mono">
                Nouveau ici ? 
                <a href="{{ path('app_register') }}" class="font-medium text-[var(--color-drac-cyan)] hover:text-[var(--color-drac-purple)] transition-colors">Créer un compte</a>
            </p>
        </form>
    </div>
</main>
{% endblock %}
