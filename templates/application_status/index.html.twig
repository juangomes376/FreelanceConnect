{% extends 'base.html.twig' %}

{% block title %}Statut de candidature - Console{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono text-[var(--color-drac-fg)]">
    <div class="max-w-7xl mx-auto space-y-8">
        
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-pink)] tracking-tight uppercase">
                    <span class="text-[var(--color-drac-comment)]">[[</span> application_state_matrix <span class="text-[var(--color-drac-comment)]">]]</span>
                </h1>
                <p class="text-sm text-[var(--color-drac-comment)] mt-1">Gestion des états du flux de candidatures...</p>
            </div>
            
            <a href="{{ path('app_application_statut_new') }}" class="inline-flex items-center px-6 py-3 bg-[var(--color-drac-pink)]/10 border border-[var(--color-drac-pink)]/30 text-[var(--color-drac-pink)] rounded-xl text-sm hover:bg-[var(--color-drac-pink)] hover:text-[var(--color-drac-bg)] transition-all uppercase tracking-widest">
                <span class="mr-2">+</span> Push_New_State
            </a>
        </div>

        <div class="bg-[var(--color-drac-surface)]/40 border border-[var(--color-drac-curr)] rounded-2xl overflow-hidden backdrop-blur-sm shadow-2xl max-w-4xl mx-auto">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-[var(--color-drac-curr)]/50 text-[var(--color-drac-comment)] uppercase tracking-wider">
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">ID</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">State_Label</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[var(--color-drac-curr)]">
                    {% for application_statut in application_statutes %}
                        <tr class="hover:bg-[var(--color-drac-pink)]/5 transition-colors group">
                            <td class="px-6 py-4 text-[var(--color-drac-comment)] font-bold">#{{ application_statut.id }}</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded bg-[var(--color-drac-fg)]/5 text-[var(--color-drac-fg)] border border-[var(--color-drac-comment)]/30 text-[10px] font-bold uppercase tracking-widest">{{ application_statut.name }}</span>
                            </td>
                            <td class="px-6 py-4 text-right space-x-3">
                                <a href="{{ path('app_application_statut_show', {'id': application_statut.id}) }}" class="text-[var(--color-drac-pink)] hover:text-[var(--color-drac-cyan)] transition-colors underline decoration-[var(--color-drac-pink)]/20 uppercase text-xs">read</a>
                                <a href="{{ path('app_application_statut_modifier', {'id': application_statut.id}) }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-yellow)] transition-colors underline decoration-[var(--color-drac-comment)]/20 uppercase text-xs">mod</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="px-6 py-20 text-center text-[var(--color-drac-comment)] italic">
                                <p class="text-lg">VOID_STATE: Index empty.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>
{% endblock %}
