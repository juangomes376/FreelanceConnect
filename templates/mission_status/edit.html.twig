{% extends 'base.html.twig' %}

{% block title %}Editar Status de Missão - Terminal{% endblock %}

{% block body %}
<main class="flex-grow flex items-center justify-center p-6 bg-[var(--color-drac-bg)] font-mono text-[var(--color-drac-fg)]">
    <div class="w-full max-w-xl bg-[var(--color-drac-surface)] border border-[var(--color-drac-curr)] p-10 rounded-2xl shadow-2xl relative neon-border-yellow">
        <div class="mb-10 flex items-center justify-between border-b border-[var(--color-drac-curr)] pb-6">
            <h1 class="text-2xl font-bold text-[var(--color-drac-yellow)] uppercase tracking-tighter">
                <span class="text-[var(--color-drac-comment)]">CMD:</span> Patch_Lifecycle_Node
            </h1>
            <a href="{{ path('app_mission_status_index') }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-fg)] text-xs uppercase tracking-widest">Abort_Command</a>
        </div>

        {{ include('mission_status/_form.html.twig', {'button_label': 'Rebase_Lifecycle_Buffer'}) }}

        <div class="mt-10 pt-8 border-t border-[var(--color-drac-curr)]">
            {{ include('mission_status/_delete_form.html.twig') }}
        </div>
    </div>
</main>
{% endblock %}
