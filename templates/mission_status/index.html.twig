{% extends 'base.html.twig' %}

{% block title %}Statut de mission - Console{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono text-[var(--color-drac-fg)]">
    <div class="max-w-7xl mx-auto space-y-8">
        
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-yellow)] tracking-tight uppercase">
                    <span class="text-[var(--color-drac-comment)]">&lt;</span> mission_lifecycle_states <span class="text-[var(--color-drac-comment)]">&gt;</span>
                </h1>
                <p class="text-sm text-[var(--color-drac-comment)] mt-1">Synchronisation des etats autorises pour les flux de travail des missions...</p>
            </div>
            
            <a href="{{ path('app_mission_statut_new') }}" class="inline-flex items-center px-6 py-3 bg-[var(--color-drac-yellow)]/10 border border-[var(--color-drac-yellow)]/30 text-[var(--color-drac-yellow)] rounded-xl text-sm hover:bg-[var(--color-drac-yellow)] hover:text-[var(--color-drac-bg)] transition-all uppercase tracking-widest">
                <span class="mr-2">+</span> Créer_Nœud_Statut
            </a>
        </div>

        <div class="bg-[var(--color-drac-surface)]/40 border border-[var(--color-drac-curr)] rounded-2xl overflow-hidden backdrop-blur-sm shadow-2xl max-w-4xl mx-auto">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-[var(--color-drac-curr)]/50 text-[var(--color-drac-comment)] uppercase tracking-wider">
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">ID</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-[var(--color-drac-yellow)]">State_Descriptor</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[var(--color-drac-curr)]">
                    {% for mission_statut in mission_statutes %}
                        <tr class="hover:bg-[var(--color-drac-yellow)]/5 transition-colors group">
                            <td class="px-6 py-4 text-[var(--color-drac-comment)] font-bold">#{{ mission_statut.id }}</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded bg-[var(--color-drac-yellow)]/5 text-[var(--color-drac-yellow)] border border-[var(--color-drac-yellow)]/30 text-[10px] font-bold uppercase tracking-widest">{{ mission_statut.name }}</span>
                            </td>
                            <td class="px-6 py-4 text-right space-x-3">
                                <a href="{{ path('app_mission_statut_show', {'id': mission_statut.id}) }}" class="text-[var(--color-drac-yellow)] hover:text-[var(--color-drac-cyan)] transition-colors underline decoration-[var(--color-drac-yellow)]/20 uppercase text-xs">read</a>
                                <a href="{{ path('app_mission_statut_modifier', {'id': mission_statut.id}) }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-pink)] transition-colors underline decoration-[var(--color-drac-comment)]/20 uppercase text-xs">mod</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="px-6 py-20 text-center text-[var(--color-drac-comment)] italic">
                                <p class="text-lg">HALT: Mission state index is empty.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>
{% endblock %}
