{% extends 'base.html.twig' %}

{% block title %}Détails du statut de mission #{{ mission_statut.id }}{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono text-[var(--color-drac-fg)]">
    <div class="max-w-4xl mx-auto space-y-8">
        
        <div class="flex items-center justify-between border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-yellow)] tracking-tighter uppercase">
                    <span class="text-[var(--color-drac-comment)]">STATE_ID:</span> #{{ mission_statut.id }}
                </h1>
                <p class="text-[var(--color-drac-cyan)] uppercase tracking-widest text-xs mt-1">Statut : Nœud_Cycle_de_Vie_Auditée</p>
            </div>
            
            <div class="flex gap-4">
                <a href="{{ path('app_mission_statut_modifier', {'id': mission_statut.id}) }}" class="px-4 py-2 border border-[var(--color-drac-yellow)]/30 text-[var(--color-drac-yellow)] text-xs rounded hover:bg-[var(--color-drac-yellow)]/10 transition-colors uppercase">Modifierifier_Nœud</a>
                <a href="{{ path('app_mission_statut_index') }}" class="px-4 py-2 border border-[var(--color-drac-comment)]/30 text-[var(--color-drac-comment)] text-xs rounded hover:bg-[var(--color-drac-comment)]/10 transition-colors uppercase">Retour_Enregistrement</a>
            </div>
        </div>

        <div class="bg-[var(--color-drac-surface)]/60 border border-[var(--color-drac-curr)] rounded-2xl p-8 backdrop-blur-sm shadow-xl neon-border-yellow relative overflow-hidden max-w-xl mx-auto">
            <div class="absolute top-0 right-0 p-4 opacity-10">
                <span class="text-[var(--color-drac-yellow)] text-[10px]">MISSION_STATE_DESCRIPTOR</span>
            </div>
            
            <h2 class="text-xs uppercase text-[var(--color-drac-green)] tracking-[0.3em] mb-6 border-b border-[var(--color-drac-curr)] pb-2">Statut_Métadonnées</h2>
            
            <div class="space-y-6 text-center py-10">
                <div>
                    <p class="text-[10px] text-[var(--color-drac-comment)] uppercase font-bold tracking-widest mb-4">Nom_De_Statut</p>
                    <p class="text-4xl font-black text-[var(--color-drac-fg)] uppercase tracking-tighter glow-green">{{ mission_statut.name }}</p>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-[var(--color-drac-red)]/20">
                <h4 class="text-[10px] text-[var(--color-drac-red)] uppercase font-bold mb-4 tracking-widest">Protocole_De_Suppression_Logique</h4>
                {{ include('mission_statut/_delete_form.html.twig') }}
            </div>
        </div>

    </div>
</main>
{% endblock %}
