<form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" onsubmit="return confirm('ALERTE : la purge de l'identité supprimera tous les enregistrements associés. Continuer ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
    <button class="w-full py-2 border border-[var(--color-drac-red)]/40 text-[var(--color-drac-red)] text-xs font-mono rounded hover:bg-[var(--color-drac-red)] hover:text-[var(--color-drac-bg)] transition-all uppercase tracking-widest">
        Executar_Purga
    </button>
</form>
