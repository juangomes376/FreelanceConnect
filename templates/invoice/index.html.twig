{% extends 'base.html.twig' %}

{% block title %}Invoice index{% endblock %}

{% block body %}
    <h1>Invoice index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>InvoiceNumber</th>
                <th>SenderSiret</th>
                <th>AmountHT</th>
                <th>TvaRate</th>
                <th>AmountTVA</th>
                <th>AmountTTC</th>
                <th>Label</th>
                <th>Type</th>
                <th>CreatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for invoice in invoices %}
            <tr>
                <td>{{ invoice.id }}</td>
                <td>{{ invoice.invoiceNumber }}</td>
                <td>{{ invoice.senderSiret }}</td>
                <td>{{ invoice.amountHT }}</td>
                <td>{{ invoice.tvaRate }}</td>
                <td>{{ invoice.amountTVA }}</td>
                <td>{{ invoice.amountTTC }}</td>
                <td>{{ invoice.label }}</td>
                <td>{{ invoice.type }}</td>
                <td>{{ invoice.createdAt ? invoice.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_invoice_show', {'id': invoice.id}) }}">show</a>
                    <a href="{{ path('app_invoice_edit', {'id': invoice.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_invoice_new') }}">Create new</a>
{% endblock %}
