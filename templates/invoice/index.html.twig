{% extends 'base.html.twig' %}

{% block title %}Console financier - Factures{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono text-[var(--color-drac-fg)]">
    <div class="max-w-7xl mx-auto space-y-8">
        
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-yellow)] tracking-tight uppercase">
                    <span class="text-[var(--color-drac-green)]">$</span> registre_financier
                </h1>
                <p class="text-sm text-[var(--color-drac-comment)] mt-1">Audit des factures et des transactions...</p>
            </div>
            
            {% if is_granted('ROLE_CLIENT') or is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_invoice_new') }}" class="inline-flex items-center px-6 py-3 bg-[var(--color-drac-yellow)]/10 border border-[var(--color-drac-yellow)]/30 text-[var(--color-drac-yellow)] rounded-xl text-sm hover:bg-[var(--color-drac-yellow)] hover:text-[var(--color-drac-bg)] transition-all shadow-lg hover:shadow-[var(--color-drac-yellow)]/20 uppercase tracking-widest">
                <span class="mr-2">+</span> Générer_Facture
            </a>
            {% endif %}
        </div>

        <div class="bg-[var(--color-drac-surface)]/40 border border-[var(--color-drac-curr)] rounded-2xl overflow-hidden backdrop-blur-sm shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-[var(--color-drac-curr)]/50 text-[var(--color-drac-comment)] uppercase tracking-wider">
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">ID</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-[var(--color-drac-yellow)]">Facture_ID</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] hidden lg:table-cell">Siret_Emetteur</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-right">Montant_TTC</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] hidden md:table-cell">Label</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">Type</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[var(--color-drac-curr)]">
                    {% for invoice in invoices %}
                        <tr class="hover:bg-[var(--color-drac-yellow)]/5 transition-colors group">
                            <td class="px-6 py-4 text-[var(--color-drac-comment)] font-bold">#{{ invoice.id }}</td>
                            <td class="px-6 py-4">
                                <span class="font-mono text-[var(--color-drac-yellow)]">{{ invoice.invoiceNumber }}</span>
                            </td>
                            <td class="px-6 py-4 hidden lg:table-cell text-xs text-[var(--color-drac-comment)]">
                                {{ invoice.senderSiret }}
                            </td>
                            <td class="px-6 py-4 text-right font-bold text-[var(--color-drac-green)]">
                                ${{ invoice.amountTTC }}
                            </td>
                            <td class="px-6 py-4 hidden md:table-cell max-w-xs truncate text-xs opacity-70">
                                {{ invoice.label }}
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-0.5 rounded bg-[var(--color-drac-purple)]/10 text-[var(--color-drac-purple)] text-[10px] border border-[var(--color-drac-purple)]/20 font-bold uppercase">{{ invoice.type }}</span>
                            </td>
                            <td class="px-6 py-4 text-right space-x-3">
                                <a href="{{ path('app_invoice_show', {'id': invoice.id}) }}" class="text-[var(--color-drac-yellow)] hover:text-[var(--color-drac-cyan)] transition-colors underline decoration-[var(--color-drac-yellow)]/20 uppercase text-xs">voir</a>
                                <a href="{{ path('app_invoice_modifier', {'id': invoice.id}) }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-pink)] transition-colors underline decoration-[var(--color-drac-comment)]/20 uppercase text-xs">mod</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="px-6 py-20 text-center text-[var(--color-drac-comment)] italic">
                                <p class="text-lg">SOLDE_ZERO : aucune archive de factures trouvée.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>
{% endblock %}
