{% extends 'base.html.twig' %}

{% block title %}Nouvel enregistrement financier - Console{% endblock %}

{% block body %}
<main class="flex-grow flex items-center justify-center p-6 bg-[var(--color-drac-bg)] font-mono">
    <div class="w-full max-w-2xl bg-[var(--color-drac-surface)] border border-[var(--color-drac-curr)] p-10 rounded-2xl shadow-2xl relative neon-border-yellow">
        <div class="mb-10 flex items-center justify-between border-b border-[var(--color-drac-curr)] pb-6">
            <h1 class="text-2xl font-bold text-[var(--color-drac-yellow)] uppercase tracking-tighter">
                <span class="text-[var(--color-drac-comment)]">CMD:</span> Generate_Invoice
            </h1>
            <a href="{{ path('app_invoice_index') }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-fg)] text-xs uppercase tracking-widest">Annuler_Commande</a>
        </div>

        {{ include('invoice/_form.html.twig', {'button_label': 'Initialize_Transaction'}) }}
    </div>
</main>
{% endblock %}
