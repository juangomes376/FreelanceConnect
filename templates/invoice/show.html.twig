{% extends 'base.html.twig' %}

{% block title %}Invoice{% endblock %}

{% block body %}
    <h1>Invoice</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ invoice.id }}</td>
            </tr>
            <tr>
                <th>InvoiceNumber</th>
                <td>{{ invoice.invoiceNumber }}</td>
            </tr>
            <tr>
                <th>SenderSiret</th>
                <td>{{ invoice.senderSiret }}</td>
            </tr>
            <tr>
                <th>AmountHT</th>
                <td>{{ invoice.amountHT }}</td>
            </tr>
            <tr>
                <th>TvaRate</th>
                <td>{{ invoice.tvaRate }}</td>
            </tr>
            <tr>
                <th>AmountTVA</th>
                <td>{{ invoice.amountTVA }}</td>
            </tr>
            <tr>
                <th>AmountTTC</th>
                <td>{{ invoice.amountTTC }}</td>
            </tr>
            <tr>
                <th>Label</th>
                <td>{{ invoice.label }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ invoice.type }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ invoice.createdAt ? invoice.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_invoice_index') }}">back to list</a>

    <a href="{{ path('app_invoice_edit', {'id': invoice.id}) }}">edit</a>

    {{ include('invoice/_delete_form.html.twig') }}
{% endblock %}
