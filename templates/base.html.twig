<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        <!-- Google Fonts: Outfit -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans antialiased">
        {% include 'navbar.html.twig' %}
        <div class="flex-grow flex flex-col">
            {% block body %}{% endblock %}
        </div>
    </body>
    <footer class="border-t border-white/5 bg-[#0a0514]/80 py-10 backdrop-blur-lg relative z-10">
        <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 sm:px-6 text-sm text-slate-400 sm:flex-row sm:items-center sm:justify-between">
            <p>© {{ "now"|date("Y") }} FreelanceConnect. Tous droits réservés.</p>
        </div>
    </footer>
</html>
