<form method="post" action="{{ path('app_category_delete', {'id': category.id}) }}" onsubmit="return confirm('ALERTE : suppression de catégorie demandée. Confirmer la purge du nœud du système ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
    <button class="w-full py-2 border border-[var(--color-drac-red)]/40 text-[var(--color-drac-red)] text-xs font-mono rounded hover:bg-[var(--color-drac-red)] hover:text-[var(--color-drac-bg)] transition-all uppercase tracking-widest">
        Purge_Node
    </button>
</form>
