{% extends 'base.html.twig' %}

{% block title %}Console des catégories{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono text-[var(--color-drac-fg)]">
    <div class="max-w-7xl mx-auto space-y-8">
        
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-cyan)] tracking-tight uppercase">
                    <span class="text-[var(--color-drac-purple)]">#</span> category_buffer
                </h1>
                <p class="text-sm text-[var(--color-drac-comment)] mt-1">Synchronisation des index de classification des missions...</p>
            </div>
            
            <a href="{{ path('app_category_new') }}" class="inline-flex items-center px-6 py-3 bg-[var(--color-drac-cyan)]/10 border border-[var(--color-drac-cyan)]/30 text-[var(--color-drac-cyan)] rounded-xl text-sm hover:bg-[var(--color-drac-cyan)] hover:text-[var(--color-drac-bg)] transition-all shadow-lg hover:shadow-[var(--color-drac-cyan)]/20 uppercase tracking-widest">
                <span class="mr-2">+</span> Add_Category_Node
            </a>
        </div>

        <div class="bg-[var(--color-drac-surface)]/40 border border-[var(--color-drac-curr)] rounded-2xl overflow-hidden backdrop-blur-sm shadow-2xl max-w-4xl mx-auto">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-[var(--color-drac-curr)]/50 text-[var(--color-drac-purple)] uppercase tracking-wider">
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">ID</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">Context_Label</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[var(--color-drac-curr)]">
                    {% for category in categories %}
                        <tr class="hover:bg-[var(--color-drac-cyan)]/5 transition-colors group">
                            <td class="px-6 py-4 text-[var(--color-drac-comment)] font-bold">#{{ category.id }}</td>
                            <td class="px-6 py-4">
                                <span class="font-bold text-[var(--color-drac-cyan)] uppercase text-xs">{{ category.name }}</span>
                            </td>
                            <td class="px-6 py-4 text-right space-x-3">
                                <a href="{{ path('app_category_show', {'id': category.id}) }}" class="text-[var(--color-drac-cyan)] hover:text-[var(--color-drac-green)] transition-colors underline decoration-[var(--color-drac-cyan)]/20 uppercase text-xs">read</a>
                                <a href="{{ path('app_category_modifier', {'id': category.id}) }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-pink)] transition-colors underline decoration-[var(--color-drac-comment)]/20 uppercase text-xs">mod</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="px-6 py-20 text-center text-[var(--color-drac-comment)] italic">
                                <p class="text-lg">INDEX_NULL : aucune catégorie définie dans le registre.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>
{% endblock %}
