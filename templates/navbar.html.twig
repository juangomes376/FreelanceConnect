<header class="sticky top-0 z-50 w-full border-b border-[var(--color-drac-curr)] bg-[var(--color-drac-bg)]/80 backdrop-blur-md">
    <input id="mobile-menu-toggle" type="checkbox" class="peer hidden" aria-label="Toggle mobile menu">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex items-center justify-between">
        <div class="flex items-center gap-4 md:gap-8">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                <span class="text-xl font-bold tracking-tight text-[var(--color-drac-purple)] font-mono">Free<span class="text-[var(--color-drac-cyan)]">Lance</span>Connect</span>
            </a>

            <nav class="hidden md:flex gap-6 font-mono">
                <a href="{{ path('app_home') }}" class="text-sm font-medium text-[var(--color-drac-fg)] hover:text-[var(--color-drac-pink)] transition-colors">Accueil</a>
                {% if is_granted('ROLE_USER') %}
                    <a href="{{ path('app_mission_index') }}" class="text-sm font-medium text-[var(--color-drac-fg)] hover:text-[var(--color-drac-pink)] transition-colors">Missions</a>
                    <a href="{{ path('app_application_index') }}" class="text-sm font-medium text-[var(--color-drac-fg)] hover:text-[var(--color-drac-pink)] transition-colors">Candidatures</a>
                    <a href="{{ path('app_invoice_index') }}" class="text-sm font-medium text-[var(--color-drac-fg)] hover:text-[var(--color-drac-pink)] transition-colors">Factures</a>
                {% endif %}

            </nav>
        </div>
        <div class="flex items-center gap-4">

            {% if app.user %}
                <details class="relative group md:block">
                    <summary class="list-none flex items-center gap-2 rounded-full bg-slate-800/60 p-1 pr-3 text-sm font-medium text-white hover:bg-slate-800 transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2 focus:ring-offset-slate-950 marker:hidden [&::-webkit-details-marker]:hidden">
                        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-cyan-500/20 text-cyan-300">
                            {{ app.user.firstName|default('U')|first|upper }}
                        </span>
                        <span class=" sm:inline-block text-slate-300">{{ app.user.firstName|default('Profil') }}</span>
                        <svg class="h-4 w-4 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                    </summary>
                    
                    <div class="absolute right-0 mt-2 w-56 origin-top-right rounded-md bg-slate-900 border border-slate-700/60 shadow-xl ring-1 ring-black ring-opacity-5 focus:outline-none z-50">
                        <div class="py-1">
                            <div class="px-4 py-3 border-b border-slate-800/60">
                                <p class="text-sm font-medium text-white">{{ app.user.firstName|default('Utilisateur') }} {% if app.user.lastName is defined %}{{ app.user.lastName }}{% endif %}</p>
                                <p class="text-xs text-slate-400 truncate mt-0.5">{{ app.user.userIdentifier }}</p>
                            </div>
                            <a href="{{ path('app_address_index') }}" class="flex px-4 py-2.5 text-sm text-slate-300 hover:bg-slate-800 hover:text-white transition-colors">Adresses</a>
                            <a href="{{ path('app_logout') }}" class="flex px-4 py-2.5 text-sm font-medium text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-colors border-t border-slate-800/60">Déconnexion</a>
                        </div>
                    </div>
                </details>
            {% else %}
                <a href="{{ path('app_login') }}" class=" md:inline-block text-sm font-medium text-slate-300 hover:text-cyan-300 transition-colors px-3 py-2">Connexion</a>
                <a href="{{ path('app_register') }}" class=" md:inline-flex items-center justify-center rounded-md bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-400 border border-cyan-400/20 hover:bg-cyan-400 hover:text-slate-950 transition-colors focus:outline-none focus:ring-2 focus:ring-cyan-300 focus:ring-offset-2 focus:ring-offset-slate-950">Inscription</a>
            {% endif %}
        </div>
    </div>

</header>

