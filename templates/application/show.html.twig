{% extends 'base.html.twig' %}

{% block title %}Candidature SPEC #{{ application.id }}{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono text-[var(--color-drac-fg)]">
    <div class="max-w-4xl mx-auto space-y-8">
        
        <div class="flex items-center justify-between border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-green)] tracking-tighter">
                    Candidature #{{ application.id }}
                </h1>
            </div>
            
            <div class="flex gap-4">
                {% if is_granted('ROLE_FREELANCE') %}
                <a href="{{ path('app_application_edit', {'id': application.id}) }}" class="px-4 py-2 border border-[var(--color-drac-purple)]/30 text-[var(--color-drac-purple)] text-xs rounded hover:bg-[var(--color-drac-purple)]/10 transition-colors uppercase">Modifier</a>
                {% endif %}
                <a href="{{ path('app_application_index') }}" class="px-4 py-2 border border-[var(--color-drac-comment)]/30 text-[var(--color-drac-comment)] text-xs rounded hover:bg-[var(--color-drac-comment)]/10 transition-colors uppercase">Retour</a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-[var(--color-drac-surface)]/60 border border-[var(--color-drac-curr)] rounded-2xl p-8 backdrop-blur-sm shadow-xl neon-border-green relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-4 opacity-20">
                        <span class="text-[var(--color-drac-green)] text-[10px]">CANDIDACY_DATA_STREAM</span>
                    </div>
                    
                    <h2 class="text-xs uppercase text-[var(--color-drac-cyan)] tracking-[0.3em] mb-6">Lettre de motivation</h2>
                    <div class="bg-[var(--color-drac-bg)]/50 p-6 border-l-2 border-[var(--color-drac-green)] rounded-r-lg text-sm leading-relaxed opacity-90 italic">
                        "{{ application.coverLetter }}"
                    </div>

                    <h2 class="text-xs uppercase text-[var(--color-drac-cyan)] tracking-[0.3em] mt-10 mb-6">Ressources</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="p-4 bg-[var(--color-drac-curr)]/30 rounded-xl border border-[var(--color-drac-curr)]">
                            <p class="text-[10px] text-[var(--color-drac-comment)] uppercase font-bold mb-1">CV</p>
                            <p class="text-xs text-[var(--color-drac-purple)] truncate">{{ application.cvFilename|default('Non fourni') }}</p>
                        </div>
                        <div class="p-4 bg-[var(--color-drac-curr)]/30 rounded-xl border border-[var(--color-drac-curr)]">
                            <p class="text-[10px] text-[var(--color-drac-comment)] uppercase font-bold mb-1">Portfolio</p>
                            <p class="text-xs text-[var(--color-drac-cyan)] truncate">{{ application.portfolioLinks|default('Non fourni') }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="bg-[var(--color-drac-surface)] border border-[var(--color-drac-curr)] rounded-2xl p-6 space-y-6">
                    <div>
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-1 font-bold">Heures estimées</p>
                        <p class="text-2xl text-[var(--color-drac-yellow)] font-bold">{{ application.hoursWorked }}h</p>
                    </div>
                    
                    <div>
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-1 font-bold">Avance demandée</p>
                        <p class="text-xl text-[var(--color-drac-orange)]">{{ application.advanceRequestedPercent }}%</p>
                    </div>

                    <div class="pt-6 border-t border-[var(--color-drac-curr)]">
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-2 font-bold">Statut financier</p>
                        <div class="flex items-center justify-between text-xs">
                            <span>Avance acceptée</span>
                            <span class="{{ application.isAdvanceAccepted ? 'text-[var(--color-drac-green)]' : 'text-[var(--color-drac-red)]' }} font-bold">
                                {{ application.isAdvanceAccepted ? 'Oui' : 'Non' }}
                            </span>
                        </div>
                    </div>
                </div>

                {% if is_granted('ROLE_FREELANCE') %}
                <div class="p-4 border border-[var(--color-drac-red)]/20 rounded-2xl bg-[var(--color-drac-red)]/5">
                    <h4 class="text-[10px] text-[var(--color-drac-red)] uppercase font-bold mb-4 tracking-widest">Supprimer la candidature</h4>
                    {{ include('application/_delete_form.html.twig') }}
                </div>
                {% endif %}
            </div>
        </div>

    </div>
</main>
{% endblock %}
