{% extends 'base.html.twig' %}

{% block title %}FreelanceConnect | Plateforme{% endblock %}

{% block body %}
<main class="relative isolate overflow-hidden bg-[var(--color-drac-bg)] text-[var(--color-drac-fg)]">
    <div class="absolute inset-x-0 top-0 -z-10 overflow-hidden blur-3xl">
        <div class="relative left-1/2 h-80 w-[72rem] -translate-x-1/2 rotate-[30deg] bg-[var(--color-drac-purple)]/20 opacity-60 blur-3xl"></div>
    </div>

    <section class="mx-auto flex min-h-[calc(100vh-160px)] max-w-7xl flex-col justify-center px-4 py-16 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
            <div class="space-y-8">
                <div class="inline-flex rounded-full bg-[var(--color-drac-curr)]/80 px-4 py-1 text-sm font-semibold uppercase tracking-[0.24em] text-[var(--color-drac-green)] ring-1 ring-[var(--color-drac-green)]/20 font-mono">
                    Projet Symfony</div>

                <div class="space-y-6">
                    <h1 class="text-4xl font-semibold tracking-tight text-[var(--color-drac-purple)] sm:text-5xl lg:text-6xl font-mono">
                        FreelanceConnect
                    </h1>
                    <p class="max-w-2xl text-lg leading-8 text-[var(--color-drac-fg)] opacity-90 sm:text-xl">
                        Une plateforme hybride Web + API pour mettre en relation, en toute sécurité, les clients et les freelances.
                        L'architecture est optimisée pour la robustesse backend, la sécurité des données et la qualité du code.
                    </p>
                </div>

                <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
                    <a href="{{ path('app_login') }}" class="inline-flex w-full items-center justify-center rounded-2xl bg-[var(--color-drac-cyan)] px-6 py-3 text-base font-semibold text-[var(--color-drac-bg)] shadow-lg shadow-[var(--color-drac-cyan)]/20 transition hover:bg-[var(--color-drac-green)] sm:w-auto font-mono">
                        Connexion
                    </a>
                    <a href="#objectifs" class="inline-flex w-full items-center justify-center rounded-2xl border border-[var(--color-drac-comment)] bg-[var(--color-drac-curr)]/50 px-6 py-3 text-base font-semibold text-[var(--color-drac-fg)] transition hover:border-[var(--color-drac-pink)] hover:text-[var(--color-drac-pink)] sm:w-auto font-mono">
                        En savoir plus
                    </a>
                </div>
            </div>

            <div class="rounded-[2rem] border border-[var(--color-drac-curr)] bg-[var(--color-drac-bg)]/50 p-8 shadow-2xl shadow-[var(--color-drac-bg)]/40 backdrop-blur-xl">
                <div class="space-y-6">
                    <div class="rounded-3xl border border-[var(--color-drac-purple)]/20 bg-[var(--color-drac-curr)]/40 p-6">
                        <p class="text-sm uppercase tracking-[0.24em] text-[var(--color-drac-purple)] font-mono">Contexte</p>
                        <p class="mt-3 text-[var(--color-drac-fg)]">Projet réalisé en mode delivery rapide sur 30 heures, avec priorité sur:</p>
                        <ul class="mt-4 space-y-3 text-[var(--color-drac-comment)]">
                            <li class="flex gap-3"><span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-[var(--color-drac-pink)]"></span>Architecture backend solide</li>
                            <li class="flex gap-3"><span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-[var(--color-drac-pink)]"></span>Sécurité et intégrité des données</li>
                            <li class="flex gap-3"><span class="mt-1 inline-flex h-2.5 w-2.5 rounded-full bg-[var(--color-drac-pink)]"></span>Qualité du code et maintenabilité</li>
                        </ul>
                    </div>
                    <div class="rounded-3xl border border-[var(--color-drac-curr)]/90 bg-[var(--color-drac-curr)]/40 p-6 text-[var(--color-drac-fg)]">
                        <p class="text-sm uppercase tracking-[0.24em] text-[var(--color-drac-cyan)] font-mono">Objectifs métier</p>
                        <p class="mt-3 leading-7 text-[var(--color-drac-comment)]">FreelanceConnect facilite la mise en relation sécurisée entre donneurs d'ordre et freelances, avec un focus sur un service fiable, simple et adapté aux besoins des deux profils.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="objectifs" class="border-t border-[var(--color-drac-curr)] bg-[var(--color-drac-bg)] px-4 py-16 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
            <div class="max-w-3xl space-y-4 text-[var(--color-drac-fg)]">
                <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-drac-pink)] font-mono">Spécifications fonctionnelles</p>
                <h2 class="text-3xl font-semibold tracking-tight text-[var(--color-drac-purple)] sm:text-4xl font-mono">Focus sur la sécurité et la fiabilité</h2>
                <p class="text-[var(--color-drac-comment)] leading-7">La plateforme est pensée pour offrir une expérience claire sans sacrifier la robustesse technique. Les pages principales restent simples et efficaces pour respecter le temps de développement.</p>
            </div>

            <div class="mt-12 grid gap-6 lg:grid-cols-3">
                <article class="rounded-3xl border border-[var(--color-drac-curr)] bg-[var(--color-drac-bg)]/80 p-8 shadow-xl shadow-[var(--color-drac-bg)]/20 hover:border-[var(--color-drac-purple)] transition-colors">
                    <h3 class="text-xl font-semibold text-[var(--color-drac-cyan)] font-mono">Clients</h3>
                    <p class="mt-4 text-[var(--color-drac-comment)] leading-7">Publier des missions, sélectionner des freelances et suivre les projets en toute confiance.</p>
                </article>
                <article class="rounded-3xl border border-[var(--color-drac-curr)] bg-[var(--color-drac-bg)]/80 p-8 shadow-xl shadow-[var(--color-drac-bg)]/20 hover:border-[var(--color-drac-purple)] transition-colors">
                    <h3 class="text-xl font-semibold text-[var(--color-drac-cyan)] font-mono">Freelances</h3>
                    <p class="mt-4 text-[var(--color-drac-comment)] leading-7">Recevoir des offres pertinentes, gérer ses candidatures et sécuriser ses prestations.</p>
                </article>
                <article class="rounded-3xl border border-[var(--color-drac-curr)] bg-[var(--color-drac-bg)]/80 p-8 shadow-xl shadow-[var(--color-drac-bg)]/20 hover:border-[var(--color-drac-purple)] transition-colors">
                    <h3 class="text-xl font-semibold text-[var(--color-drac-cyan)] font-mono">API / Backend</h3>
                    <p class="mt-4 text-[var(--color-drac-comment)] leading-7">Architecture prête pour intégration API, avec un backend robuste et sécurisé.</p>
                </article>
            </div>
        </div>
    </section>
</main>
{% endblock %}
