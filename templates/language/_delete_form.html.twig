<form method="post" action="{{ path('app_language_delete', {'id': language.id}) }}" onsubmit="return confirm('ALERTA: Remocao de biblioteca solicitada. Confirmar purga de arquivos binarios?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ language.id) }}">
    <button class="w-full py-2 border border-[var(--color-drac-red)]/40 text-[var(--color-drac-red)] text-xs font-mono rounded hover:bg-[var(--color-drac-red)] hover:text-[var(--color-drac-bg)] transition-all uppercase tracking-widest">
        Purge_Library
    </button>
</form>
