{% extends 'base.html.twig' %}

{% block title %}Novo Registro - Terminal{% endblock %}

{% block body %}
<main class="flex-grow flex items-center justify-center p-6 bg-[var(--color-drac-bg)]">
    <div class="w-full max-w-2xl bg-[var(--color-drac-surface)] border border-[var(--color-drac-curr)] p-10 rounded-2xl shadow-2xl relative neon-border-purple">
        <div class="mb-10 flex items-center justify-between border-b border-[var(--color-drac-curr)] pb-6">
            <h1 class="text-2xl font-bold text-[var(--color-drac-purple)] font-mono uppercase tracking-tighter">
                <span class="text-[var(--color-drac-comment)]">CMD:</span> New_Mission
            </h1>
            <a href="{{ path('app_mission_index') }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-fg)] font-mono text-xs uppercase tracking-widest">Abort_Command</a>
        </div>

        {{ include('mission/_form.html.twig') }}
    </div>
</main>
{% endblock %}
