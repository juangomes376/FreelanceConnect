{% extends 'base.html.twig' %}

{% block title %}Console des missions{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)]">
    <div class="max-w-7xl mx-auto space-y-8">
        
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-fg)] font-mono tracking-tight uppercase">
                    <span class="text-[var(--color-drac-green)]">missions</span>
                </h1>
                <p class="text-sm text-[var(--color-drac-comment)] font-mono mt-1">Exploration de la base de données des contrats disponibles...</p>
            </div>
            
            {% if is_granted('ROLE_CLIENT') %}
            <a href="{{ path('app_mission_new') }}" class="inline-flex items-center px-6 py-3 bg-[var(--color-drac-green)]/10 border border-[var(--color-drac-green)]/30 text-[var(--color-drac-green)] rounded-xl font-mono text-sm hover:bg-[var(--color-drac-green)] hover:text-[var(--color-drac-bg)] transition-all shadow-lg hover:shadow-[var(--color-drac-green)]/20 uppercase tracking-widest">
                <span class="mr-2">+</span> Nouvelle mission
            </a>
            {% endif %}
        </div>

        {# Main Table Container #}
        <div class="bg-[var(--color-drac-surface)]/40 border border-[var(--color-drac-curr)] rounded-2xl overflow-hidden backdrop-blur-sm shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse font-mono text-sm">
                    <thead>
                        <tr class="bg-[var(--color-drac-curr)]/50 text-[var(--color-drac-cyan)] uppercase tracking-wider">
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">ID</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">Titre</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] hidden lg:table-cell">Budget</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] hidden md:table-cell">Delai</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)]">Statut</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-center">Actions</th>
                            <th class="px-6 py-4 border-b border-[var(--color-drac-curr)] text-center">Candidatures</th>
                        </tr>
                    </thead>
                    <tbody class="text-[var(--color-drac-fg)] divide-y divide-[var(--color-drac-curr)]">
                    {% for mission in missions %}
                        <tr class="hover:bg-[var(--color-drac-purple)]/5 transition-colors group">
                            <td class="px-6 py-4 text-[var(--color-drac-comment)]">#{{ mission.id }}</td>
                            <td class="px-6 py-4">
                                <a href="{{ path('app_mission_show', {'id': mission.id}) }}" class="font-bold text-[var(--color-drac-purple)] underline decoration-[var(--color-drac-purple)]/30 hover:decoration-[var(--color-drac-purple)] transition-all">{{ mission.title }}</a>
                            </td>
                            <td class="px-6 py-4 hidden lg:table-cell text-[var(--color-drac-green)] font-bold">
                                ${{ mission.budget }}
                            </td>
                            <td class="px-6 py-4 hidden md:table-cell text-[var(--color-drac-comment)]">
                                {{ mission.deadline ? mission.deadline|date('d/m/Y') : '--/--/----' }}
                            </td>
                            <td class="px-6 py-4">
                                {% if mission.isValidatedByAdmin %}
                                    <span class="inline-flex items-center px-2 py-1 rounded bg-[var(--color-drac-green)]/10 text-[var(--color-drac-green)] text-xs border border-[var(--color-drac-green)]/20">VALIDATED</span>
                                {% else %}
                                    <span class="inline-flex items-center px-2 py-1 rounded bg-[var(--color-drac-orange)]/10 text-[var(--color-drac-orange)] text-xs border border-[var(--color-drac-orange)]/20">PENDING</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-center space-x-3">
                                {% if is_granted('ROLE_CLIENT') or is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_mission_edit', {'id': mission.id}) }}" class="text-[var(--color-drac-comment)] hover:text-[var(--color-drac-purple)] transition-colors underline decoration-[var(--color-drac-comment)]/20">modifier</a>
                                {% endif %}
                                {% if is_granted('ROLE_FREELANCE') %}
                                <a href="{{ path('app_application_new_mission', {'id': mission.id}) }}" class="text-[var(--color-drac-green)] hover:text-[var(--color-drac-green)]/80 transition-colors underline decoration-[var(--color-drac-green)]/20">postuler</a>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="text-[var(--color-drac-comment)] italic text-xs">{{mission.applicationCount}}</span>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-20 text-center text-[var(--color-drac-comment)] italic font-mono">
                                <p class="text-lg">Aucune mission trouvée.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</main>
{% endblock %}
