{% extends 'base.html.twig' %}

{% block title %}Détails de la mission #{{ mission.id }}{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono">
    <div class="max-w-4xl mx-auto space-y-8">
        
        <div class="flex items-center justify-between border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-purple)] tracking-tighter">
                    Mission #{{ mission.id }} &mdash; {{ mission.title }}
                </h1>
            </div>
            
            <div class="flex gap-4">
                {% if is_granted('ROLE_CLIENT') or is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_mission_edit', {'id': mission.id}) }}" class="px-4 py-2 border border-[var(--color-drac-purple)]/30 text-[var(--color-drac-purple)] text-xs rounded hover:bg-[var(--color-drac-purple)]/10 transition-colors uppercase">Modifier</a>
                {% endif %}
                <a href="{{ path('app_mission_index') }}" class="px-4 py-2 border border-[var(--color-drac-comment)]/30 text-[var(--color-drac-comment)] text-xs rounded hover:bg-[var(--color-drac-comment)]/10 transition-colors uppercase">Retour</a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {# Main Info Block #}
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-[var(--color-drac-surface)]/60 border border-[var(--color-drac-curr)] rounded-2xl p-8 backdrop-blur-sm shadow-xl neon-border-purple relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-4">
                        <span class="text-[var(--color-drac-green)] text-[10px] opacity-30">ENCRYPT_V2.4</span>
                    </div>
                    
                    <h2 class="text-xs uppercase text-[var(--color-drac-cyan)] tracking-[0.3em] mb-4">Titre</h2>
                    <h3 class="text-2xl font-bold text-[var(--color-drac-fg)] mb-6">{{ mission.title }}</h3>
                    
                    <div class="space-y-4">
                        <h2 class="text-xs uppercase text-[var(--color-drac-cyan)] tracking-[0.3em] mt-8 mb-2">Description</h2>
                        <div class="text-[var(--color-drac-fg)] opacity-80 leading-relaxed text-sm bg-[var(--color-drac-bg)]/50 p-4 border-l-2 border-[var(--color-drac-purple)] rounded-r-lg">
                            {{ mission.description }}
                        </div>
                    </div>
                </div>

                {# Bloc postuler — ROLE_FREELANCE uniquement #}
                {% if is_granted('ROLE_FREELANCE') %}
                <div class="bg-[var(--color-drac-surface)]/60 border border-[var(--color-drac-green)]/30 rounded-2xl p-6 shadow-xl">
                    <h2 class="text-xs uppercase text-[var(--color-drac-green)] tracking-[0.3em] mb-4">Candidater à cette mission</h2>
                    {% if alreadyApplied %}
                        <p class="text-sm text-[var(--color-drac-comment)] italic">Vous avez déjà soumis une candidature pour cette mission.</p>
                    {% elseif mission.isValidatedByAdmin %}
                        <p class="text-sm text-[var(--color-drac-fg)] opacity-80 mb-4">Cette mission est ouverte aux candidatures. Envoyez votre dossier (lettre de motivation, CV, portfolio).</p>
                        <a href="{{ path('app_application_new_mission', {'id': mission.id}) }}"
                           class="inline-flex items-center px-6 py-3 bg-[var(--color-drac-green)]/10 border border-[var(--color-drac-green)]/40 text-[var(--color-drac-green)] rounded-xl text-sm hover:bg-[var(--color-drac-green)] hover:text-[var(--color-drac-bg)] transition-all font-mono uppercase tracking-widest">
                            Postuler
                        </a>
                    {% else %}
                        <p class="text-sm text-[var(--color-drac-comment)] italic">Cette mission n'est pas encore ouverte aux candidatures (en attente de validation).</p>
                    {% endif %}
                </div>
                {% endif %}

                {# Bloc candidatures reçues — ROLE_CLIENT / ROLE_ADMIN uniquement #}
                {% if is_granted('ROLE_CLIENT') or is_granted('ROLE_ADMIN') %}
                <div class="bg-[var(--color-drac-surface)]/60 border border-[var(--color-drac-cyan)]/30 rounded-2xl p-6 shadow-xl">
                    <h2 class="text-xs uppercase text-[var(--color-drac-cyan)] tracking-[0.3em] mb-4">Candidatures reçues</h2>
                    <div class="flex items-center justify-between">
                        <p class="text-2xl font-bold text-[var(--color-drac-cyan)]">{{ mission.applications|length }}</p>
                        <a href="{{ path('app_mission_applications', {'id': mission.id}) }}"
                           class="inline-flex items-center px-4 py-2 bg-[var(--color-drac-cyan)]/10 border border-[var(--color-drac-cyan)]/30 text-[var(--color-drac-cyan)] rounded-lg text-xs hover:bg-[var(--color-drac-cyan)] hover:text-[var(--color-drac-bg)] transition-all font-mono uppercase">
                            Voir toutes les candidatures →
                        </a>
                    </div>
                </div>
                {% endif %}
            </div>

            {# Metadata Sidebar #}
            <div class="space-y-6">
                <div class="bg-[var(--color-drac-surface)] border border-[var(--color-drac-curr)] rounded-2xl p-6 space-y-6">
                    <div>
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-1 font-bold">Budget</p>
                        <p class="text-2xl text-[var(--color-drac-green)] font-bold">${{ mission.budget }}</p>
                    </div>
                    
                    <div>
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-1 font-bold">Date limite</p>
                        <p class="text-lg text-[var(--color-drac-fg)]">{{ mission.deadline ? mission.deadline|date('d F Y') : 'Non définie' }}</p>
                        <p class="text-[10px] text-[var(--color-drac-comment)] mt-1 uppercase">{{ mission.deadline ? mission.deadline|date('H:i:s T') : '' }}</p>
                    </div>

                    <div class="pt-6 border-t border-[var(--color-drac-curr)]">
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-2 font-bold">Statut</p>
                        <div class="space-y-2">
                            <div class="flex items-center justify-between text-xs">
                                <span>Validé par un admin</span>
                                <span class="{{ mission.isValidatedByAdmin ? 'text-[var(--color-drac-green)]' : 'text-[var(--color-drac-red)]' }} font-bold">
                                    {{ mission.isValidatedByAdmin ? 'Oui' : 'Non' }}
                                </span>
                            </div>
                            <div class="flex items-center justify-between text-xs">
                                <span>Revalidation requise</span>
                                <span class="{{ mission.needsRevalidation ? 'text-[var(--color-drac-pink)]' : 'text-[var(--color-drac-comment)]' }}">
                                    {{ mission.needsRevalidation ? 'Oui' : 'Non' }}
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                {% if is_granted('ROLE_CLIENT') or is_granted('ROLE_ADMIN') %}
                <div class="p-4 border border-[var(--color-drac-red)]/20 rounded-2xl bg-[var(--color-drac-red)]/5">
                    <h4 class="text-[10px] text-[var(--color-drac-red)] uppercase font-bold mb-4 tracking-widest">Supprimer la mission</h4>
                    {{ include('mission/_delete_form.html.twig') }}
                </div>
                {% endif %}
            </div>
        </div>

    </div>
</main>
{% endblock %}
