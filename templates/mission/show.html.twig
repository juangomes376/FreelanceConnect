{% extends 'base.html.twig' %}

{% block title %}Detalhes da Missao #{{ mission.id }}{% endblock %}

{% block body %}
<main class="flex-grow p-6 lg:p-10 bg-[var(--color-drac-bg)] font-mono">
    <div class="max-w-4xl mx-auto space-y-8">
        
        <div class="flex items-center justify-between border-b border-[var(--color-drac-curr)] pb-6">
            <div>
                <h1 class="text-3xl font-bold text-[var(--color-drac-purple)] tracking-tighter uppercase">
                    <span class="text-[var(--color-drac-comment)]">FILE_ID:</span> #{{ mission.id }}
                </h1>
                <p class="text-[var(--color-drac-pink)] uppercase tracking-widest text-xs mt-1">Classificado: Alta Prioridade</p>
            </div>
            
            <div class="flex gap-4">
                <a href="{{ path('app_mission_edit', {'id': mission.id}) }}" class="px-4 py-2 border border-[var(--color-drac-purple)]/30 text-[var(--color-drac-purple)] text-xs rounded hover:bg-[var(--color-drac-purple)]/10 transition-colors uppercase">Edit_Entry</a>
                <a href="{{ path('app_mission_index') }}" class="px-4 py-2 border border-[var(--color-drac-comment)]/30 text-[var(--color-drac-comment)] text-xs rounded hover:bg-[var(--color-drac-comment)]/10 transition-colors uppercase">Close_Terminal</a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {# Main Info Block #}
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-[var(--color-drac-surface)]/60 border border-[var(--color-drac-curr)] rounded-2xl p-8 backdrop-blur-sm shadow-xl neon-border-purple relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-4">
                        <span class="text-[var(--color-drac-green)] text-[10px] opacity-30">ENCRYPT_V2.4</span>
                    </div>
                    
                    <h2 class="text-xs uppercase text-[var(--color-drac-cyan)] tracking-[0.3em] mb-4">Objectivo_Principal</h2>
                    <h3 class="text-2xl font-bold text-[var(--color-drac-fg)] mb-6">{{ mission.title }}</h3>
                    
                    <div class="space-y-4">
                        <h2 class="text-xs uppercase text-[var(--color-drac-cyan)] tracking-[0.3em] mt-8 mb-2">Descricao_Protocolo</h2>
                        <div class="text-[var(--color-drac-fg)] opacity-80 leading-relaxed text-sm bg-[var(--color-drac-bg)]/50 p-4 border-l-2 border-[var(--color-drac-purple)] rounded-r-lg">
                            {{ mission.description }}
                        </div>
                    </div>
                </div>
            </div>

            {# Metadata Sidebar #}
            <div class="space-y-6">
                <div class="bg-[var(--color-drac-surface)] border border-[var(--color-drac-curr)] rounded-2xl p-6 space-y-6">
                    <div>
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-1 font-bold">Orcamento_Alocado</p>
                        <p class="text-2xl text-[var(--color-drac-green)] font-bold">${{ mission.budget }}</p>
                    </div>
                    
                    <div>
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-1 font-bold">Prazo_Final</p>
                        <p class="text-lg text-[var(--color-drac-fg)]">{{ mission.deadline ? mission.deadline|date('d F Y') : 'NOT_SET' }}</p>
                        <p class="text-[10px] text-[var(--color-drac-comment)] mt-1 uppercase">{{ mission.deadline ? mission.deadline|date('H:i:s T') : '' }}</p>
                    </div>

                    <div class="pt-6 border-t border-[var(--color-drac-curr)]">
                        <p class="text-[10px] text-[var(--color-drac-comment)] uppercase tracking-wider mb-2 font-bold">Status_Seguranca</p>
                        <div class="space-y-2">
                            <div class="flex items-center justify-between text-xs">
                                <span>Validated by Admin</span>
                                <span class="{{ mission.isValidatedByAdmin ? 'text-[var(--color-drac-green)]' : 'text-[var(--color-drac-red)]' }} font-bold">
                                    {{ mission.isValidatedByAdmin ? 'TRUE' : 'FALSE' }}
                                </span>
                            </div>
                            <div class="flex items-center justify-between text-xs">
                                <span>Needs Revalidation</span>
                                <span class="{{ mission.needsRevalidation ? 'text-[var(--color-drac-pink)]' : 'text-[var(--color-drac-comment)]' }}">
                                    {{ mission.needsRevalidation ? 'YES' : 'NO' }}
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-4 border border-[var(--color-drac-red)]/20 rounded-2xl bg-[var(--color-drac-red)]/5">
                    <h4 class="text-[10px] text-[var(--color-drac-red)] uppercase font-bold mb-4 tracking-widest">Protocolo_De_Exclusao</h4>
                    {{ include('mission/_delete_form.html.twig') }}
                </div>
            </div>
        </div>

    </div>
</main>
{% endblock %}
