{% extends 'base.html.twig' %}

{% block title %}Mission{% endblock %}

{% block body %}
    <h1>Mission</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ mission.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ mission.title }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ mission.description }}</td>
            </tr>
            <tr>
                <th>Budget</th>
                <td>{{ mission.budget }}</td>
            </tr>
            <tr>
                <th>Deadline</th>
                <td>{{ mission.deadline ? mission.deadline|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>IsValidatedByAdmin</th>
                <td>{{ mission.isValidatedByAdmin ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>NeedsRevalidation</th>
                <td>{{ mission.needsRevalidation ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_mission_index') }}">back to list</a>

    <a href="{{ path('app_mission_edit', {'id': mission.id}) }}">edit</a>

    {{ include('mission/_delete_form.html.twig') }}
{% endblock %}
